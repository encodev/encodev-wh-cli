#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="Encodev WH CLI"
APP_DIR="/root/wh-cli"
BACKUP_DIR="$APP_DIR/backups"
CREDENTIALS_DIR="$APP_DIR/sites"
CADDY_AVAILABLE="/etc/caddy/sites-available"
CADDY_ENABLED="/etc/caddy/sites-enabled"
LOGROTATE_CONFIG="/etc/logrotate.d/encodev-wh-cli"
MAINTENANCE_CRON_CONFIG="/etc/cron.d/encodev-wh-cli-maintenance"
MAINTENANCE_RETENTION_DAYS=7
MAINTENANCE_RETENTION_MINUTES=$((MAINTENANCE_RETENTION_DAYS * 24 * 60))
SFTP_GROUP="sftp-sites"
SFTP_DENIED_REQUESTS="symlink,hardlink"
SFTP_UMASK="027"
DEFAULT_TIMEZONE="America/Toronto"
DEFAULT_LOCALE="en_CA.UTF-8"
ADMINER_DIR="/usr/share/adminer"
ADMINER_FILE="$ADMINER_DIR/adminer.php"
ADMINER_TMP_DIR="/var/lib/wh-cli/adminer-tmp"
ADMINER_VERSION="5.4.2"
ADMINER_REPO="vrana/adminer"
ADMINER_TAG="v${ADMINER_VERSION}"
ADMINER_ASSET="adminer-${ADMINER_VERSION}-mysql-en.php"
ADMINER_URL="https://github.com/${ADMINER_REPO}/releases/download/${ADMINER_TAG}/${ADMINER_ASSET}"
ADMINER_ASSET_SHA256="b90f7e113497ee65e6f2e7f3eb2d953cdcfc44ef5ae2ca5ee8d39794c713f7e7"
DB_HOST="127.0.0.1"
WP_CLI_VERSION="2.12.0"
WP_CLI_REPO="wp-cli/wp-cli"
WP_CLI_TAG="v${WP_CLI_VERSION}"
WP_CLI_ASSET="wp-cli-${WP_CLI_VERSION}.phar"
WP_CLI_URL="https://github.com/${WP_CLI_REPO}/releases/download/${WP_CLI_TAG}/${WP_CLI_ASSET}"
WP_CLI_ASSET_SHA256="ce34ddd838f7351d6759068d09793f26755463b4a4610a5a5c0a97b68220d85c"
SURY_APT_KEY_FINGERPRINT="15058500A0235D97F5D10063B188E2B695BD4743"
MANAGED_BEGIN="# BEGIN encodev-wh-cli managed"
MANAGED_END="# END encodev-wh-cli managed"
DISABLED_PHP_FUNCTIONS="exec,passthru,shell_exec,system,proc_open,popen,pcntl_exec,curl_multi_exec,parse_ini_file,show_source"
PHP_EXTENSIONS=(cli mysql curl mbstring xml zip gd intl bcmath soap imagick opcache)
PHP_EOL_VERSIONS=(8.1 8.0 7.4 7.3 7.2 7.1 7.0 5.6)
SENSITIVE_PATH_REGEXP='(?i)(?:(^|/)(?:\.git|\.svn|\.hg)(?:/|$)|(^|/)(?:\.env[^/]*|\.htaccess|\.htpasswd|\.user\.ini|wp-config\.php|composer\.(?:json|lock)|auth\.json|package(?:-lock)?\.json|yarn\.lock|pnpm-lock\.yaml)$|\.(?:sql|sqlite3?|db|bak|backup|old|orig|save|sw[op]|tmp)$)'
STATIC_EXECUTABLE_REGEXP='(?i)\.(?:php[0-9]?|phtml|phar|phps|cgi|pl|py|rb|sh|bash|zsh|ksh)$'
PHP_STATIC_EXECUTABLE_REGEXP='(?i)\.(?:php[0-9]+|phtml|phar|phps|cgi|pl|py|rb|sh|bash|zsh|ksh)$'
UPLOAD_EXECUTABLE_REGEXP='(?i)^/(?:wp-content/uploads|uploads|data|cache)/.*\.(?:php[0-9]?|phtml|phar|phps|cgi|pl|py|rb|sh|bash|zsh|ksh)$'

require_root() {
    if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
        echo "This script must be run as root."
        exit 1
    fi
}

pause() {
    read -r -p "Press Enter to continue..."
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

require_command() {
    local command_name=$1

    if ! command_exists "$command_name"; then
        echo "Missing required command: $command_name" >&2
        return 1
    fi
}

ensure_app_dirs() {
    mkdir -p "$APP_DIR" "$BACKUP_DIR" "$CREDENTIALS_DIR"
    chmod 700 "$APP_DIR" "$BACKUP_DIR" "$CREDENTIALS_DIR"
}

prompt() {
    local label=$1
    local default=${2:-}
    local value

    if [[ -n "$default" ]]; then
        printf '%s [%s]: ' "$label" "$default" >&2
        read -r value
        printf '%s\n' "${value:-$default}"
    else
        printf '%s: ' "$label" >&2
        read -r value
        printf '%s\n' "$value"
    fi
}

confirm() {
    local label=$1
    local default=${2:-n}
    local suffix="[y/N]"
    local answer

    [[ "$default" == "y" ]] && suffix="[Y/n]"
    printf '%s %s ' "$label" "$suffix" >&2
    read -r answer
    answer=${answer:-$default}

    [[ "$answer" =~ ^[Yy]$ ]]
}

validate_ipv4() {
    local ip=$1
    local part
    local -a parts

    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    IFS='.' read -r -a parts <<< "$ip"
    for part in "${parts[@]}"; do
        [[ "$part" =~ ^[0-9]+$ ]] || return 1
        (( part >= 0 && part <= 255 )) || return 1
    done
}

validate_port() {
    local port=$1
    [[ "$port" =~ ^[0-9]+$ ]] && (( port >= 1 && port <= 65535 ))
}

validate_php_version() {
    local version=$1
    [[ "$version" =~ ^[0-9]+[.][0-9]+$ ]]
}

validate_domain() {
    local domain=${1,,}
    [[ ${#domain} -le 253 ]] || return 1
    [[ "$domain" =~ ^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$ ]]
}

validate_username() {
    local username=$1
    [[ "$username" =~ ^[a-z_][a-z0-9_-]{0,30}$ ]]
}

detect_admin_user() {
    local user=${SUDO_USER:-}

    if [[ -n "$user" && "$user" != "root" ]] && id "$user" >/dev/null 2>&1; then
        printf '%s\n' "$user"
    fi
}

require_admin_ssh_user() {
    local user=$1
    local entry shell status

    if [[ -z "$user" ]]; then
        echo "Enter an existing non-root user that can keep SSH admin access." >&2
        return 1
    fi
    if [[ "$user" == "root" ]]; then
        echo "Root cannot be the SSH admin user because setup disables root SSH login." >&2
        return 1
    fi
    if ! entry=$(getent passwd "$user"); then
        echo "Admin user does not exist: $user" >&2
        return 1
    fi

    shell=${entry##*:}
    case "$shell" in
        ""|/usr/sbin/nologin|/sbin/nologin|/bin/false|/usr/bin/false)
            echo "Admin user does not have an interactive login shell: $user ($shell)" >&2
            return 1
            ;;
    esac
    if [[ -r /etc/shells ]] && ! grep -Fxq "$shell" /etc/shells; then
        echo "Admin user's shell is not listed in /etc/shells: $user ($shell)" >&2
        return 1
    fi

    if ! id -nG "$user" | tr ' ' '\n' | grep -Eq '^(sudo|admin)$'; then
        echo "Admin user must belong to the sudo or admin group: $user" >&2
        return 1
    fi

    status=$(passwd -S "$user" 2>/dev/null | awk '{print $2}' || true)
    if [[ "$status" != "P" ]]; then
        echo "Admin user must have an unlocked password for SSH password login: $user" >&2
        return 1
    fi
}

validate_timezone() {
    if command_exists timedatectl && timedatectl list-timezones 2>/dev/null | grep -Fxq "$1"; then
        return 0
    fi
    [[ "$1" != *".."* && -f "/usr/share/zoneinfo/$1" ]]
}

detect_hostname() {
    local detected
    detected=$(hostname -f 2>/dev/null || hostname 2>/dev/null || true)
    if [[ -z "$detected" || "$detected" == "localhost" || "$detected" != *.* ]]; then
        detected="server.example.com"
    fi
    printf '%s\n' "$detected"
}

detect_ssh_client_ip() {
    local detected=""
    if [[ -n "${SSH_CLIENT:-}" ]]; then
        detected=${SSH_CLIENT%% *}
    fi

    if validate_ipv4 "$detected"; then
        printf '%s\n' "$detected"
    fi
}

detect_ssh_port() {
    local detected=""
    if [[ -n "${SSH_CONNECTION:-}" ]]; then
        read -r _ _ _ detected <<< "$SSH_CONNECTION"
    fi

    if validate_port "$detected"; then
        printf '%s\n' "$detected"
    else
        printf '%s\n' "22"
    fi
}

sshd_configured_for_port() {
    local port=$1
    local configured found=0

    if ! command_exists sshd; then
        echo "Missing required command: sshd." >&2
        return 1
    fi

    while IFS= read -r configured; do
        [[ "$configured" == "$port" ]] && found=1
    done < <(sshd -T 2>/dev/null | awk '$1 == "port" { print $2 }')

    if (( found == 0 )); then
        echo "OpenSSH is not configured to listen on TCP port $port." >&2
        echo "Check the current SSH port before enabling UFW." >&2
        return 1
    fi
}

sshd_listening_on_port() {
    local port=$1
    local line local_addr found_port=0
    local -a fields

    require_command ss || return 1

    while IFS= read -r line; do
        read -r -a fields <<< "$line"
        [[ ${#fields[@]} -ge 4 ]] || continue
        local_addr=${fields[3]}
        [[ "$local_addr" == *":$port" ]] || continue

        found_port=1
        if [[ "$line" == *sshd* ]]; then
            return 0
        fi
    done < <(ss -H -ltnp 2>/dev/null || true)

    if (( found_port != 0 )); then
        echo "TCP port $port is listening, but the listener does not appear to be sshd." >&2
    else
        echo "No active sshd listener found on TCP port $port." >&2
    fi
    return 1
}

require_active_ssh_port() {
    local port=$1

    validate_port "$port" || {
        echo "Invalid SSH port: $port" >&2
        return 1
    }
    sshd_configured_for_port "$port" || return 1
    sshd_listening_on_port "$port" || return 1
}

username_from_domain() {
    local domain=${1,,}
    local username
    username=$(printf '%s' "$domain" \
        | tr '.-' '_' \
        | tr -cs 'a-z0-9_' '_' \
        | sed -E 's/^_+//; s/_+$//; s/_{2,}/_/g')
    [[ -z "$username" ]] && username="domain"
    username="site_$username"
    printf '%s\n' "$username" | cut -c1-31
}

db_name_from_username() {
    printf '%s\n' "$1" | tr '-' '_' | cut -c1-48
}

validate_database_name() {
    local db_name=$1
    [[ "$db_name" =~ ^[a-z_][a-z0-9_]{0,47}$ ]]
}

mysql_sql_string_literal() {
    local value=$1
    value=${value//\'/\'\'}
    printf "'%s'" "$value"
}

mysql_database_identifier() {
    local db_name=$1

    validate_database_name "$db_name" || {
        echo "Invalid database name: $db_name" >&2
        return 1
    }
    printf '%s%s%s' '`' "$db_name" '`'
}

mysql_grant_database_identifier() {
    local db_name=$1

    validate_database_name "$db_name" || {
        echo "Invalid database name: $db_name" >&2
        return 1
    }

    db_name=${db_name//_/\\_}
    db_name=${db_name//%/\\%}
    printf '%s%s%s' '`' "$db_name" '`'
}

random_secret() {
    if ! command_exists openssl; then
        echo "openssl is required to generate credentials. Run setup first." >&2
        return 1
    fi
    openssl rand -hex 16
}

assert_supported_os() {
    local os_id codename

    if [[ ! -r /etc/os-release ]]; then
        echo "Cannot detect operating system from /etc/os-release." >&2
        return 1
    fi

    os_id=$(awk -F= '$1 == "ID" { gsub(/"/, "", $2); print $2 }' /etc/os-release)
    codename=$(awk -F= '$1 == "VERSION_CODENAME" { gsub(/"/, "", $2); print $2 }' /etc/os-release)

    if [[ "$os_id" != "debian" ]]; then
        echo "This installer currently supports Debian only. Detected: ${os_id:-unknown}" >&2
        return 1
    fi
    if [[ -z "$codename" ]]; then
        echo "Could not detect the Debian codename from /etc/os-release." >&2
        return 1
    fi
}

service_is_active() {
    local service=$1
    command_exists systemctl && systemctl is-active --quiet "$service" 2>/dev/null
}

service_is_enabled() {
    local service=$1
    command_exists systemctl && systemctl is-enabled --quiet "$service" 2>/dev/null
}

require_caddy_user() {
    if ! id caddy >/dev/null 2>&1; then
        echo "Missing caddy system user. Run setup before managing sites." >&2
        return 1
    fi
}

check_conflicting_web_servers() {
    local service failed=0

    for service in apache2 nginx; do
        if service_is_active "$service"; then
            echo "$service is active and may already be using ports 80/443." >&2
            failed=1
        elif service_is_enabled "$service"; then
            echo "$service is enabled and may take ports 80/443 after reboot." >&2
            failed=1
        fi
    done

    if (( failed != 0 )); then
        echo "Stop or migrate conflicting web servers before running setup." >&2
        return 1
    fi
}

preflight_setup_environment() {
    assert_supported_os || return 1
    require_command apt || return 1
    require_command systemctl || return 1

    if [[ ! -d /run/systemd/system ]]; then
        echo "systemd does not appear to be running. This installer manages system services." >&2
        return 1
    fi

    check_conflicting_web_servers
}

is_managed_file() {
    local path=$1
    [[ -f "$path" ]] && grep -q '^# Managed by encodev-wh-cli' "$path"
}

is_managed_php_pool() {
    local path=$1
    [[ -f "$path" ]] && grep -q '^; Managed by encodev-wh-cli' "$path"
}

require_managed_php_pool_or_missing() {
    local path=$1
    local label=$2

    if path_exists "$path" && ! is_managed_php_pool "$path"; then
        echo "$label exists and is not managed by encodev-wh-cli: $path" >&2
        echo "Refusing to overwrite or move it." >&2
        return 1
    fi
}

remove_managed_php_pool_if_exists() {
    local path=$1

    path_exists "$path" || return 0
    if ! is_managed_php_pool "$path"; then
        echo "Refusing to remove unmanaged PHP-FPM pool: $path" >&2
        return 0
    fi
    if ! rm -f "$path"; then
        echo "Failed to remove managed PHP-FPM pool: $path" >&2
    fi
}

metadata_value() {
    local key=$1
    local file=$2

    sed -n "s/^# $key: //p" "$file" | head -n 1
}

managed_caddy_files() {
    local file

    [[ -d "$CADDY_AVAILABLE" ]] || return 0

    shopt -s nullglob
    for file in "$CADDY_AVAILABLE"/*; do
        [[ -f "$file" ]] || continue
        grep -q '^# Managed by encodev-wh-cli' "$file" || continue
        printf '%s\n' "$file"
    done
    shopt -u nullglob
}

caddy_claimed_hosts_for_metadata() {
    local domain=$1
    local type=$2
    local www_policy=${3:-none}

    [[ -n "$domain" ]] || return 0

    printf '%s\n' "$domain"
    if [[ "$type" == "admin" || "$domain" == www.* ]]; then
        return 0
    fi

    case "$www_policy" in
        redirect_www|redirect_apex|serve_both)
            printf 'www.%s\n' "$domain"
            ;;
    esac
}

caddy_config_claims_host() {
    local file=$1
    local requested_host=$2
    local domain type www_policy host

    domain=$(metadata_value domain "$file")
    type=$(metadata_value type "$file")
    www_policy=$(metadata_value www "$file")

    while IFS= read -r host; do
        [[ "$host" == "$requested_host" ]] && return 0
    done < <(caddy_claimed_hosts_for_metadata "$domain" "$type" "$www_policy")

    return 1
}

require_caddy_hosts_available() {
    local domain=$1
    local type=$2
    local www_policy=${3:-none}
    local skip_file=${4:-}
    local requested_host file failed=0

    while IFS= read -r requested_host; do
        while IFS= read -r file; do
            [[ -n "$skip_file" && "$file" == "$skip_file" ]] && continue
            if caddy_config_claims_host "$file" "$requested_host"; then
                echo "Hostname already claimed by managed Caddy config: $requested_host ($file)" >&2
                failed=1
            fi
        done < <(managed_caddy_files)
    done < <(caddy_claimed_hosts_for_metadata "$domain" "$type" "$www_policy")

    (( failed == 0 ))
}

path_exists() {
    [[ -e "$1" || -L "$1" ]]
}

require_managed_or_missing() {
    local path=$1
    local label=$2

    if path_exists "$path" && ! is_managed_file "$path"; then
        echo "$label exists and is not managed by encodev-wh-cli: $path" >&2
        echo "Refusing to overwrite it. Move it aside or add it manually." >&2
        return 1
    fi
}

require_webroot_without_symlinks() {
    local webroot=$1
    local first_symlink

    if [[ -L "$webroot" ]]; then
        echo "Refusing to enable site with a symlinked web root: $webroot" >&2
        echo "Caddy follows symlinks, which can expose files outside the site root." >&2
        return 1
    fi
    if [[ ! -d "$webroot" ]]; then
        echo "Missing web root: $webroot" >&2
        return 1
    fi

    if ! first_symlink=$(find "$webroot" -type l -print -quit); then
        echo "Could not scan web root for symlinks: $webroot" >&2
        return 1
    fi
    if [[ -n "$first_symlink" ]]; then
        echo "Refusing to enable site with a symlink inside the web root: $first_symlink" >&2
        echo "Caddy follows symlinks, which can expose files outside the site root." >&2
        return 1
    fi
}

require_caddy_config_webroot_safe() {
    local conf=$1
    local type webroot

    type=$(metadata_value type "$conf")
    [[ "$type" == "admin" ]] && return 0

    webroot=$(metadata_value webroot "$conf")
    if [[ -z "$webroot" ]]; then
        echo "Managed Caddy config is missing webroot metadata: $conf" >&2
        return 1
    fi

    require_webroot_without_symlinks "$webroot"
}

is_default_caddyfile() {
    local path=$1
    local normalized

    [[ -f "$path" ]] || return 1

    normalized=$(sed -E \
        -e 's/[[:space:]]*#.*$//' \
        -e 's/^[[:space:]]+//' \
        -e 's/[[:space:]]+$//' \
        -e '/^$/d' \
        "$path")

    [[ "$normalized" == $':80 {\nroot * /usr/share/caddy\nfile_server\n}' ]]
}

restore_file_from_backup() {
    local path=$1
    local backup

    backup=$(backup_path_for "$path")
    if path_exists "$backup"; then
        mkdir -p "$(dirname "$path")"
        cp -a "$backup" "$path"
    else
        rm -f "$path"
    fi
}

download_verified_github_asset() {
    local asset=$1
    local url=$2
    local expected=$3
    local dest=$4
    local tmp actual

    if [[ ! "$expected" =~ ^[a-fA-F0-9]{64}$ ]]; then
        echo "Invalid pinned SHA-256 checksum for $asset." >&2
        return 1
    fi

    tmp=$(mktemp)
    if ! curl -fsSL "$url" -o "$tmp"; then
        rm -f "$tmp"
        return 1
    fi

    actual=$(sha256sum "$tmp" | awk '{print $1}')
    if [[ "${actual,,}" != "${expected,,}" ]]; then
        rm -f "$tmp"
        echo "Checksum verification failed for $asset." >&2
        echo "Expected: $expected" >&2
        echo "Actual:   $actual" >&2
        return 1
    fi

    if ! install -m 0644 "$tmp" "$dest"; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
}

normalize_fingerprint() {
    printf '%s' "$1" | tr -d '[:space:]' | tr '[:lower:]' '[:upper:]'
}

keyring_has_fingerprint() {
    local keyring=$1
    local expected

    expected=$(normalize_fingerprint "$2")
    if [[ ! "$expected" =~ ^[A-F0-9]{40}$ ]]; then
        echo "Invalid pinned OpenPGP fingerprint: $2" >&2
        return 1
    fi

    gpg --show-keys --with-colons "$keyring" 2>/dev/null \
        | awk -F: -v expected="$expected" '$1 == "fpr" && toupper($10) == expected { found = 1 } END { exit found ? 0 : 1 }'
}

install_apt_keyring() {
    local url=$1
    local dest=$2
    local expected_fingerprint=$3
    local key_tmp gpg_tmp

    key_tmp=$(mktemp)
    gpg_tmp=$(mktemp)
    if ! curl -fsSL "$url" -o "$key_tmp"; then
        rm -f "$key_tmp" "$gpg_tmp"
        return 1
    fi
    if ! gpg --batch --yes --dearmor -o "$gpg_tmp" "$key_tmp"; then
        rm -f "$key_tmp" "$gpg_tmp"
        return 1
    fi
    if ! keyring_has_fingerprint "$gpg_tmp" "$expected_fingerprint"; then
        echo "Downloaded APT key fingerprint mismatch for $url." >&2
        echo "Expected: $(normalize_fingerprint "$expected_fingerprint")" >&2
        echo "Actual fingerprints:" >&2
        gpg --show-keys --with-colons "$gpg_tmp" 2>/dev/null \
            | awk -F: '$1 == "fpr" { print "  " $10 }' >&2 || true
        rm -f "$key_tmp" "$gpg_tmp"
        return 1
    fi
    if ! backup_file "$dest"; then
        rm -f "$key_tmp" "$gpg_tmp"
        return 1
    fi
    if ! install -m 0644 "$gpg_tmp" "$dest"; then
        rm -f "$key_tmp" "$gpg_tmp"
        return 1
    fi
    rm -f "$key_tmp" "$gpg_tmp"
}

ensure_apt_keyring() {
    local url=$1
    local dest=$2
    local expected_fingerprint=$3

    if [[ -f "$dest" ]] && keyring_has_fingerprint "$dest" "$expected_fingerprint"; then
        return 0
    fi

    [[ -f "$dest" ]] && echo "Replacing unexpected APT keyring: $dest" >&2
    install_apt_keyring "$url" "$dest" "$expected_fingerprint"
}

php_socket_ref() {
    local php_version=$1
    local username=$2

    validate_php_version "$php_version" || {
        echo "Invalid PHP version: $php_version" >&2
        return 1
    }
    validate_username "$username" || {
        echo "Invalid username: $username" >&2
        return 1
    }
    printf 'unix//run/php/php%s-fpm-%s.sock\n' "$php_version" "$username"
}

enable_caddy_config() {
    local conf=$1
    local enabled

    enabled="$CADDY_ENABLED/$(basename "$conf")"

    require_caddy_config_webroot_safe "$conf" || return 1

    backup_file "$enabled"
    ln -sfn "$conf" "$enabled"

    if ! caddy validate --config /etc/caddy/Caddyfile; then
        rm -f "$enabled"
        restore_file_from_backup "$enabled"
        return 1
    fi

    if ! systemctl reload caddy; then
        rm -f "$enabled"
        restore_file_from_backup "$enabled"
        systemctl reload caddy || true
        return 1
    fi
}

start_backup_run() {
    CURRENT_BACKUP_DIR="$BACKUP_DIR/$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$CURRENT_BACKUP_DIR"
    chmod 700 "$CURRENT_BACKUP_DIR"
}

setup_failure_report() {
    local status=$?

    trap - ERR
    echo >&2
    echo "Setup failed during: ${CURRENT_SETUP_STEP:-unknown step}" >&2
    if [[ -n "${CURRENT_BACKUP_DIR:-}" ]]; then
        echo "Backup: $CURRENT_BACKUP_DIR" >&2
    fi
    echo "No automatic rollback was performed." >&2
    return "$status"
}

run_setup_step() {
    local label=$1
    shift

    CURRENT_SETUP_STEP=$label
    echo "==> $label"
    "$@"
}

backup_path_for() {
    local path=$1
    printf '%s%s\n' "$CURRENT_BACKUP_DIR" "$path"
}

backup_file() {
    local path=$1
    local dest

    [[ -f "$path" || -L "$path" ]] || return 0
    [[ -n "${CURRENT_BACKUP_DIR:-}" ]] || start_backup_run

    dest=$(backup_path_for "$path")
    mkdir -p "$(dirname "$dest")"
    cp -a "$path" "$dest"
}

prune_backups() {
    local old_backups
    mapfile -t old_backups < <(find "$BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d | sort | head -n -30)
    if (( ${#old_backups[@]} > 0 )); then
        rm -rf "${old_backups[@]}"
    fi
}

write_file() {
    local path=$1
    local tmp

    tmp=$(mktemp)
    if ! cat > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    if ! backup_file "$path"; then
        rm -f "$tmp"
        return 1
    fi
    if ! install -m 0644 "$tmp" "$path"; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
}

service_state() {
    local service=$1
    if ! command_exists systemctl; then
        printf '%s\n' "unknown"
    elif systemctl is-active --quiet "$service" 2>/dev/null; then
        printf '%s\n' "running"
    elif systemctl list-unit-files "$service.service" >/dev/null 2>&1; then
        printf '%s\n' "installed"
    else
        printf '%s\n' "missing"
    fi
}

installed_php_versions() {
    local dir version
    for dir in /etc/php/*/fpm; do
        [[ -d "$dir" ]] || continue
        version=$(basename "$(dirname "$dir")")
        validate_php_version "$version" || continue
        printf '%s\n' "$version"
    done | sort -Vr
}

php_packages_for_version() {
    local version=$1
    local ext

    validate_php_version "$version" || {
        echo "Invalid PHP version: $version" >&2
        return 1
    }

    printf 'php%s-fpm\n' "$version"
    for ext in "${PHP_EXTENSIONS[@]}"; do
        printf 'php%s-%s\n' "$version" "$ext"
    done
}

apt_package_available() {
    local package=$1

    apt-cache show "$package" >/dev/null 2>&1
}

php_version_packages_available() {
    local version=$1
    local verbose=${2:-n}
    local package missing=0

    while IFS= read -r package; do
        if ! apt_package_available "$package"; then
            [[ "$verbose" == "y" ]] && echo "Missing package for PHP $version: $package" >&2
            missing=1
        fi
    done < <(php_packages_for_version "$version")

    (( missing == 0 ))
}

available_php_versions() {
    local version

    apt-cache search '^php[0-9]+\.[0-9]+-fpm$' 2>/dev/null \
        | awk '{print $1}' \
        | sed -E 's/^php([0-9]+\.[0-9]+)-fpm$/\1/' \
        | while IFS= read -r version; do
            validate_php_version "$version" || continue
            php_version_packages_available "$version" || continue
            printf '%s\n' "$version"
        done \
        | sort -Vr
}

php_is_eol() {
    local version=$1
    local eol_version

    for eol_version in "${PHP_EOL_VERSIONS[@]}"; do
        [[ "$version" == "$eol_version" ]] && return 0
    done
    return 1
}

select_php_versions_to_install() {
    local versions=()
    local choices
    local default_index=0
    local i version label index exists

    mapfile -t versions < <(available_php_versions)
    if (( ${#versions[@]} == 0 )); then
        for version in 8.4 8.3 8.2 8.1 7.4 5.6; do
            php_version_packages_available "$version" || continue
            versions+=("$version")
        done
    fi
    if (( ${#versions[@]} == 0 )); then
        echo "No complete PHP-FPM package sets are available. Check the configured APT repositories." >&2
        return 1
    fi

    echo >&2
    echo "Select PHP-FPM version(s) to install:" >&2
    for i in "${!versions[@]}"; do
        version=${versions[$i]}
        label="PHP $version"
        php_is_eol "$version" && label="$label (EOL)"
        printf '  %d. %s\n' "$((i + 1))" "$label" >&2
        if ! php_is_eol "$version" && [[ $default_index -eq 0 ]]; then
            default_index=$((i + 1))
        fi
    done
    [[ $default_index -eq 0 ]] && default_index=1

    printf 'Enter one or more numbers, separated by spaces or commas [%s]: ' "$default_index" >&2
    read -r choices
    choices=${choices:-$default_index}
    choices=${choices//,/ }

    SELECTED_PHP_VERSIONS=()
    for index in $choices; do
        [[ "$index" =~ ^[0-9]+$ ]] || continue
        (( index >= 1 && index <= ${#versions[@]} )) || continue
        exists=0
        for version in "${SELECTED_PHP_VERSIONS[@]}"; do
            [[ "$version" == "${versions[$((index - 1))]}" ]] && exists=1
        done
        (( exists == 0 )) && SELECTED_PHP_VERSIONS+=("${versions[$((index - 1))]}")
    done

    if (( ${#SELECTED_PHP_VERSIONS[@]} == 0 )); then
        SELECTED_PHP_VERSIONS=("${versions[$((default_index - 1))]}")
    fi

    printf 'Selected PHP versions: %s\n' "${SELECTED_PHP_VERSIONS[*]}" >&2
}

select_installed_php_version() {
    local versions=()
    local i selected

    mapfile -t versions < <(installed_php_versions)
    if (( ${#versions[@]} == 0 )); then
        echo "No PHP-FPM versions are installed. Run setup first." >&2
        return 1
    fi

    echo >&2
    echo "Installed PHP-FPM versions:" >&2
    for i in "${!versions[@]}"; do
        printf '  %d. PHP %s\n' "$((i + 1))" "${versions[$i]}" >&2
    done

    printf 'Select PHP version [1]: ' >&2
    read -r selected
    selected=${selected:-1}
    [[ "$selected" =~ ^[0-9]+$ ]] || selected=1
    (( selected >= 1 && selected <= ${#versions[@]} )) || selected=1
    printf '%s\n' "${versions[$((selected - 1))]}"
}

prepare_repositories() {
    local codename

    codename=$(awk -F= '$1 == "VERSION_CODENAME" { gsub(/"/, "", $2); print $2 }' /etc/os-release)

    apt update
    apt install -y ca-certificates curl gnupg apt-transport-https

    ensure_apt_keyring \
        https://packages.sury.org/php/apt.gpg \
        /usr/share/keyrings/deb.sury.org-php.gpg \
        "$SURY_APT_KEY_FINGERPRINT"

    write_file /etc/apt/sources.list.d/php-sury.list <<EOF
deb [signed-by=/usr/share/keyrings/deb.sury.org-php.gpg] https://packages.sury.org/php/ $codename main
EOF

    apt update
}

install_php_versions() {
    local version packages=() version_packages=()

    for version in "${SELECTED_PHP_VERSIONS[@]}"; do
        php_version_packages_available "$version" "y" || return 1
        mapfile -t version_packages < <(php_packages_for_version "$version")
        packages+=("${version_packages[@]}")
    done

    apt install -y "${packages[@]}"
    for version in "${SELECTED_PHP_VERSIONS[@]}"; do
        systemctl enable "php$version-fpm" --now
    done
}

configure_caddy_base() {
    mkdir -p "$CADDY_AVAILABLE" "$CADDY_ENABLED"
    if path_exists /etc/caddy/Caddyfile \
        && ! is_managed_file /etc/caddy/Caddyfile \
        && ! is_default_caddyfile /etc/caddy/Caddyfile; then
        echo "/etc/caddy/Caddyfile exists and is not managed by encodev-wh-cli." >&2
        echo "Refusing to overwrite it. Move it aside or migrate it manually." >&2
        return 1
    fi
    write_file /etc/caddy/Caddyfile <<EOF
# Managed by encodev-wh-cli
import $CADDY_ENABLED/*
EOF
}

configure_timezone_and_locales() {
    local timezone=$1

    timedatectl set-timezone "$timezone"
    apt install -y locales
    backup_file /etc/locale.gen

    grep -q '^en_CA.UTF-8 UTF-8' /etc/locale.gen \
        || sed -i -E 's/^# ?(en_CA.UTF-8 UTF-8)/\1/' /etc/locale.gen
    grep -q '^fr_CA.UTF-8 UTF-8' /etc/locale.gen \
        || sed -i -E 's/^# ?(fr_CA.UTF-8 UTF-8)/\1/' /etc/locale.gen
    grep -q '^en_CA.UTF-8 UTF-8' /etc/locale.gen || echo 'en_CA.UTF-8 UTF-8' >> /etc/locale.gen
    grep -q '^fr_CA.UTF-8 UTF-8' /etc/locale.gen || echo 'fr_CA.UTF-8 UTF-8' >> /etc/locale.gen

    locale-gen en_CA.UTF-8 fr_CA.UTF-8
    update-locale "LANG=$DEFAULT_LOCALE"
}

ufw_is_active() {
    ufw status 2>/dev/null | grep -q '^Status: active$'
}

restore_ufw_rules_from_backup() {
    local was_active=${1:-0}

    restore_file_from_backup /etc/ufw/user.rules
    restore_file_from_backup /etc/ufw/user6.rules

    if [[ "$was_active" == "1" ]]; then
        ufw reload >/dev/null 2>&1 || ufw --force enable >/dev/null 2>&1 || true
    else
        ufw --force disable >/dev/null 2>&1 || true
    fi
}

configure_ufw() {
    local admin_ip=$1
    local ssh_port=$2
    local ufw_was_active=0

    require_active_ssh_port "$ssh_port" || return 1
    ufw_is_active && ufw_was_active=1

    backup_file /etc/ufw/user.rules
    backup_file /etc/ufw/user6.rules

    if ! ufw --force reset; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
    if ! ufw default deny incoming; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
    if ! ufw default allow outgoing; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
    if ! ufw allow from "$admin_ip" to any port "$ssh_port" proto tcp comment 'encodev admin ssh'; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
    if ! ufw allow 80/tcp comment 'encodev http'; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
    if ! ufw allow 443/tcp comment 'encodev https'; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
    if ! ufw --force enable; then
        restore_ufw_rules_from_backup "$ufw_was_active"
        return 1
    fi
}

configure_fail2ban() {
    local ssh_port=$1

    apt install -y fail2ban
    mkdir -p /etc/fail2ban/jail.d
    write_file /etc/fail2ban/jail.d/encodev-wh-cli.conf <<EOF
[sshd]
enabled = true
port = $ssh_port
maxretry = 5
findtime = 10m
bantime = 1h
EOF
    systemctl enable fail2ban --now
    systemctl restart fail2ban
}

ssh_config_has_active_match() {
    local config=$1
    local pattern file

    grep -Eq '^[[:space:]]*Match[[:space:]]+' "$config" && return 0

    while read -r pattern; do
        [[ -n "$pattern" ]] || continue
        [[ "$pattern" == /* ]] || pattern="/etc/ssh/$pattern"
        for file in $pattern; do
            [[ -f "$file" ]] || continue
            grep -Eq '^[[:space:]]*Match[[:space:]]+' "$file" && return 0
        done
    done < <(awk '/^[[:space:]]*Include[[:space:]]+/ { for (i = 2; i <= NF; i++) print $i }' "$config")

    return 1
}

strip_managed_block() {
    local input=$1
    local output=$2

    awk -v begin="$MANAGED_BEGIN" -v end="$MANAGED_END" '
        $0 == begin {
            if (skip) {
                printf "Nested managed block begin marker at line %d.\n", NR > "/dev/stderr"
                failed = 1
                exit 2
            }
            skip = 1
            begin_count++
            next
        }
        $0 == end {
            if (!skip) {
                printf "Managed block end marker appears before begin marker at line %d.\n", NR > "/dev/stderr"
                failed = 1
                exit 2
            }
            skip = 0
            end_count++
            next
        }
        !skip { print }
        END {
            if (failed) {
                exit 2
            }
            if (skip) {
                printf "Managed block begin marker is missing a matching end marker.\n" > "/dev/stderr"
                exit 2
            }
            if (begin_count != end_count) {
                printf "Managed block markers are unbalanced: %d begin, %d end.\n", begin_count, end_count > "/dev/stderr"
                exit 2
            }
        }
    ' "$input" > "$output"
}

configure_sshd() {
    local admin_user=$1
    local config=/etc/ssh/sshd_config
    local hardening_dropin=/etc/ssh/sshd_config.d/00-encodev-wh-cli.conf
    local tmp

    require_admin_ssh_user "$admin_user" || return 1

    backup_file "$config"
    tmp=$(mktemp)

    if ! strip_managed_block "$config" "$tmp"; then
        echo "Refusing to rewrite SSH config with an invalid managed block." >&2
        rm -f "$tmp"
        return 1
    fi

    if ssh_config_has_active_match "$tmp"; then
        echo "$config or an included SSH config contains an unmanaged Match block." >&2
        echo "Refusing to rewrite SSH config automatically." >&2
        rm -f "$tmp"
        return 1
    fi

    if grep -Eq '^[#[:space:]]*PermitRootLogin[[:space:]]+' "$tmp"; then
        sed -i -E 's/^[#[:space:]]*PermitRootLogin[[:space:]]+.*/PermitRootLogin no/' "$tmp"
    else
        printf '\nPermitRootLogin no\n' >> "$tmp"
    fi

    if grep -Eq '^[#[:space:]]*PasswordAuthentication[[:space:]]+' "$tmp"; then
        sed -i -E 's/^[#[:space:]]*PasswordAuthentication[[:space:]]+.*/PasswordAuthentication yes/' "$tmp"
    else
        printf 'PasswordAuthentication yes\n' >> "$tmp"
    fi

    if grep -Eq '^[#[:space:]]*KbdInteractiveAuthentication[[:space:]]+' "$tmp"; then
        sed -i -E 's/^[#[:space:]]*KbdInteractiveAuthentication[[:space:]]+.*/KbdInteractiveAuthentication no/' "$tmp"
    else
        printf 'KbdInteractiveAuthentication no\n' >> "$tmp"
    fi

    cat >> "$tmp" <<EOF

$MANAGED_BEGIN
Match Group $SFTP_GROUP
    PasswordAuthentication yes
    KbdInteractiveAuthentication no
    ChrootDirectory %h
    ForceCommand internal-sftp -u $SFTP_UMASK -P $SFTP_DENIED_REQUESTS
    AllowTcpForwarding no
    X11Forwarding no
    PermitTunnel no
$MANAGED_END
EOF

    mkdir -p /etc/ssh/sshd_config.d
    if ! write_file "$hardening_dropin" <<EOF
# Managed by encodev-wh-cli
PermitRootLogin no
PasswordAuthentication yes
KbdInteractiveAuthentication no
EOF
    then
        rm -f "$tmp"
        return 1
    fi

    if ! sshd -t -f "$tmp"; then
        restore_file_from_backup "$hardening_dropin"
        rm -f "$tmp"
        return 1
    fi
    if ! install -m 0644 "$tmp" "$config"; then
        restore_file_from_backup "$hardening_dropin"
        rm -f "$tmp"
        return 1
    fi
    if ! systemctl reload ssh && ! systemctl reload sshd; then
        restore_file_from_backup "$config"
        restore_file_from_backup "$hardening_dropin"
        systemctl reload ssh || systemctl reload sshd || true
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
}

secure_mariadb() {
    systemctl enable mariadb --now
    mysql -uroot <<'SQL'
DELETE FROM mysql.user WHERE User='';
DROP DATABASE IF EXISTS test;
DELETE FROM mysql.db WHERE Db='test' OR Db='test\_%';
DELETE FROM mysql.user WHERE User='root' AND Host NOT IN ('localhost', '127.0.0.1', '::1');
FLUSH PRIVILEGES;
SQL
}

install_wp_cli() {
    download_verified_github_asset "$WP_CLI_ASSET" "$WP_CLI_URL" "$WP_CLI_ASSET_SHA256" /usr/local/bin/wp
    chmod +x /usr/local/bin/wp
    wp --info --allow-root >/dev/null
}

create_adminer_pool() {
    local php_version=$1
    local user=wwwadminer
    local pool

    validate_php_version "$php_version" || {
        echo "Invalid PHP version: $php_version" >&2
        return 1
    }
    pool="/etc/php/$php_version/fpm/pool.d/adminer.conf"
    require_managed_php_pool_or_missing "$pool" "Adminer PHP-FPM pool" || return 1

    if ! id "$user" >/dev/null 2>&1; then
        useradd -r -U -d "$ADMINER_DIR" -s /usr/sbin/nologin "$user" || return 1
    fi

    mkdir -p /var/log/wh-cli || return 1
    chown root:"$user" /var/log/wh-cli || return 1
    chmod 770 /var/log/wh-cli || return 1
    touch /var/log/wh-cli/adminer-php-error.log || return 1
    chown "$user:$user" /var/log/wh-cli/adminer-php-error.log || return 1
    chmod 640 /var/log/wh-cli/adminer-php-error.log || return 1
    mkdir -p "$ADMINER_TMP_DIR" || return 1
    chown "$user:$user" "$ADMINER_TMP_DIR" || return 1
    chmod 700 "$ADMINER_TMP_DIR" || return 1

    write_file "$pool" <<EOF
; Managed by encodev-wh-cli
[adminer]
user = $user
group = $user
listen = /run/php/php$php_version-fpm-adminer.sock
listen.owner = caddy
listen.group = caddy
listen.mode = 0660
pm = ondemand
pm.max_children = 3
pm.process_idle_timeout = 10s
php_admin_value[open_basedir] = $ADMINER_DIR:$ADMINER_TMP_DIR
php_admin_value[upload_tmp_dir] = $ADMINER_TMP_DIR
php_admin_value[session.save_path] = $ADMINER_TMP_DIR
php_admin_value[sys_temp_dir] = $ADMINER_TMP_DIR
php_admin_value[error_log] = /var/log/wh-cli/adminer-php-error.log
php_admin_flag[log_errors] = on
php_admin_flag[display_errors] = off
php_admin_flag[expose_php] = off
php_admin_value[cgi.fix_pathinfo] = 0
php_admin_value[disable_functions] = $DISABLED_PHP_FUNCTIONS
EOF

    systemctl restart "php$php_version-fpm"
}

install_adminer() {
    local admin_host=$1
    local admin_ip=$2
    local php_version=$3
    local conf="$CADDY_AVAILABLE/_admin-$admin_host"

    if path_exists "$conf" && ! is_managed_file "$conf"; then
        echo "Admin Caddy config exists and is not managed: $conf" >&2
        return 1
    fi
    require_caddy_hosts_available "$admin_host" "admin" "none" "$conf" || return 1

    mkdir -p "$ADMINER_DIR" || return 1
    download_verified_github_asset "$ADMINER_ASSET" "$ADMINER_URL" "$ADMINER_ASSET_SHA256" "$ADMINER_FILE" || return 1
    chown -R root:root "$ADMINER_DIR" || return 1
    chmod 755 "$ADMINER_DIR" || return 1
    chmod 644 "$ADMINER_FILE" || return 1

    create_adminer_pool "$php_version" || return 1

    write_file "$conf" <<EOF
# Managed by encodev-wh-cli
# domain: $admin_host
# type: admin
# user: wwwadminer
# php: $php_version
# webroot: $ADMINER_DIR

$admin_host {
    @adminer_allowed {
        path /dba /dba/*
        remote_ip $admin_ip
    }
    @adminer path /dba /dba/*

    header {
        X-Content-Type-Options nosniff
        X-Robots-Tag "noindex, nofollow"
        Referrer-Policy no-referrer
    }

    handle @adminer_allowed {
        uri strip_prefix /dba
        root * $ADMINER_DIR
        rewrite * /adminer.php
        php_fastcgi unix//run/php/php$php_version-fpm-adminer.sock
    }

    respond @adminer "Forbidden" 403
    respond "Not Found" 404
}
EOF

    enable_caddy_config "$conf"
}

configure_logrotate() {
    write_file "$LOGROTATE_CONFIG" <<'EOF'
# Managed by encodev-wh-cli
/home/site_*/logs/access.log /home/site_*/logs/error.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
    su caddy caddy
}

/home/site_*/logs/php-error.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
    su root root
}

/var/log/wh-cli/*.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
    su wwwadminer wwwadminer
}
EOF
}

configure_maintenance_cron() {
    write_file "$MAINTENANCE_CRON_CONFIG" <<'EOF'
# Managed by encodev-wh-cli
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

0 4 * * * root /usr/local/bin/wh maintenance
EOF
}

install_base_packages() {
    apt install -y caddy mariadb-server ufw curl wget unzip git openssl sudo acl openssh-server iproute2 logrotate cron
    systemctl enable caddy --now
    systemctl enable cron --now
}

setup_server() {
    local admin_host admin_ip admin_user ssh_port timezone primary_php

    ensure_app_dirs
    preflight_setup_environment || return 1

    admin_host=$(prompt "Public admin host for /dba" "$(detect_hostname)")
    while ! validate_domain "$admin_host"; do
        echo "Enter a valid hostname, for example server.example.com."
        admin_host=$(prompt "Public admin host for /dba" "$admin_host")
    done

    admin_ip=$(prompt "Admin IPv4 allowed for SSH and /dba" "$(detect_ssh_client_ip)")
    while ! validate_ipv4 "$admin_ip"; do
        echo "Enter a valid IPv4 address."
        admin_ip=$(prompt "Admin IPv4 allowed for SSH and /dba" "$admin_ip")
    done

    admin_user=$(prompt "Non-root sudo/admin SSH user" "$(detect_admin_user)")
    while ! require_admin_ssh_user "$admin_user"; do
        admin_user=$(prompt "Non-root sudo/admin SSH user" "$admin_user")
    done

    ssh_port=$(prompt "Current SSH port" "$(detect_ssh_port)")
    while ! validate_port "$ssh_port"; do
        echo "Enter a valid TCP port from 1 to 65535."
        ssh_port=$(prompt "Current SSH port" "$ssh_port")
    done

    timezone=$(prompt "Server timezone" "$DEFAULT_TIMEZONE")
    while ! validate_timezone "$timezone"; do
        echo "Unknown timezone."
        timezone=$(prompt "Server timezone" "$DEFAULT_TIMEZONE")
    done

    if path_exists /etc/caddy/Caddyfile \
        && ! is_managed_file /etc/caddy/Caddyfile \
        && ! is_default_caddyfile /etc/caddy/Caddyfile; then
        echo "/etc/caddy/Caddyfile exists and is not managed by encodev-wh-cli." >&2
        echo "Refusing to overwrite it. Move it aside or migrate it manually." >&2
        return 1
    fi

    echo
    echo "Setup summary"
    echo "  Admin host:      $admin_host"
    echo "  Admin IPv4:      $admin_ip"
    echo "  SSH admin user:  $admin_user"
    echo "  SSH port:        $ssh_port"
    echo "  SSH password:    enabled for non-root users"
    echo "  Timezone:        $timezone"
    echo "  Locales:         en_CA.UTF-8, fr_CA.UTF-8"
    echo "  Default locale:  $DEFAULT_LOCALE"
    echo "  PHP versions:    choose after repositories are prepared"
    echo "  MariaDB:         install and harden with root socket auth"
    echo "  Caddy:           install Debian package and use sites-enabled imports"
    echo "  UFW:             SSH port $ssh_port from $admin_ip only, public 80/443"
    echo "  Fail2ban:        SSH jail"
    echo "  Adminer:         https://$admin_host/dba, IP restricted"
    echo "  Backups:         $BACKUP_DIR/<timestamp>"
    echo

    if ! confirm "Apply setup changes?" "n"; then
        return 0
    fi

    CURRENT_SETUP_STEP="starting setup"
    trap setup_failure_report ERR

    run_setup_step "Start backup run" start_backup_run
    run_setup_step "Prepare repositories" prepare_repositories
    run_setup_step "Select PHP versions" select_php_versions_to_install
    if (( ${#SELECTED_PHP_VERSIONS[@]} == 0 )); then
        echo "No PHP versions were selected." >&2
        return 1
    fi
    primary_php=${SELECTED_PHP_VERSIONS[0]}

    run_setup_step "Install base packages" install_base_packages
    run_setup_step "Install PHP versions" install_php_versions
    run_setup_step "Configure timezone and locales" configure_timezone_and_locales "$timezone"
    run_setup_step "Configure Caddy base" configure_caddy_base
    run_setup_step "Configure logrotate" configure_logrotate
    run_setup_step "Configure maintenance cron" configure_maintenance_cron
    run_setup_step "Create SFTP group" groupadd -f "$SFTP_GROUP"
    run_setup_step "Configure UFW" configure_ufw "$admin_ip" "$ssh_port"
    run_setup_step "Configure SSH" configure_sshd "$admin_user"
    run_setup_step "Verify active SSH port" require_active_ssh_port "$ssh_port"
    run_setup_step "Configure Fail2ban" configure_fail2ban "$ssh_port"
    run_setup_step "Secure MariaDB" secure_mariadb
    run_setup_step "Install WP-CLI" install_wp_cli
    run_setup_step "Install Adminer" install_adminer "$admin_host" "$admin_ip" "$primary_php"
    run_setup_step "Validate Caddy" caddy validate --config /etc/caddy/Caddyfile
    run_setup_step "Reload Caddy" systemctl reload caddy
    run_setup_step "Prune backups" prune_backups

    trap - ERR
    unset CURRENT_SETUP_STEP

    echo
    echo "Setup complete."
    echo "Adminer: https://$admin_host/dba"
    echo "Backup:  $CURRENT_BACKUP_DIR"
}

install_php_versions_menu() {
    ensure_app_dirs
    assert_supported_os || return 1
    require_command apt || return 1
    require_command systemctl || return 1
    if [[ ! -d /run/systemd/system ]]; then
        echo "systemd does not appear to be running. PHP-FPM services cannot be managed." >&2
        return 1
    fi

    echo
    echo "Install additional PHP-FPM versions"
    echo "This prepares the Sury PHP repository and installs selected PHP-FPM packages."
    echo

    if ! confirm "Continue?" "y"; then
        return 0
    fi

    start_backup_run
    prepare_repositories
    select_php_versions_to_install
    install_php_versions
    prune_backups

    echo "Installed PHP versions: ${SELECTED_PHP_VERSIONS[*]}"
    echo "Backup: $CURRENT_BACKUP_DIR"
}

site_type_prompt() {
    local choice
    echo >&2
    echo "Site type:" >&2
    echo "  1. WordPress" >&2
    echo "  2. Custom PHP" >&2
    echo "  3. Static" >&2
    printf 'Select type [1]: ' >&2
    read -r choice
    case "${choice:-1}" in
        1) printf '%s\n' "wordpress" ;;
        2) printf '%s\n' "php" ;;
        3) printf '%s\n' "static" ;;
        *) printf '%s\n' "wordpress" ;;
    esac
}

www_policy_prompt() {
    local domain=$1
    local choice

    if [[ "$domain" == www.* ]]; then
        printf '%s\n' "none"
        return 0
    fi

    echo >&2
    echo "WWW alias for $domain:" >&2
    echo "  1. Redirect www.$domain to $domain" >&2
    echo "  2. Redirect $domain to www.$domain" >&2
    echo "  3. Serve both names" >&2
    echo "  4. Do not configure www" >&2
    printf 'Select www behavior [1]: ' >&2
    read -r choice

    case "${choice:-1}" in
        1) printf '%s\n' "redirect_www" ;;
        2) printf '%s\n' "redirect_apex" ;;
        3) printf '%s\n' "serve_both" ;;
        4) printf '%s\n' "none" ;;
        *) printf '%s\n' "redirect_www" ;;
    esac
}

www_policy_label() {
    local domain=$1
    local policy=$2

    case "$policy" in
        redirect_www) printf 'www.%s -> %s\n' "$domain" "$domain" ;;
        redirect_apex) printf '%s -> www.%s\n' "$domain" "$domain" ;;
        serve_both) printf '%s and www.%s\n' "$domain" "$domain" ;;
        *) printf '%s\n' "none" ;;
    esac
}

create_site_user() {
    local username=$1
    local home=$2
    local password=$3

    groupadd -f "$SFTP_GROUP"
    require_caddy_user || return 1
    if ! id "$username" >/dev/null 2>&1; then
        useradd -U -d "$home" -s /usr/sbin/nologin -G "$SFTP_GROUP" "$username" || return 1
    fi

    printf '%s:%s\n' "$username" "$password" | chpasswd || return 1

    mkdir -p "$home/public_html" "$home/logs" "$home/tmp" || return 1
    chown root:root "$home" || return 1
    chmod 751 "$home" || return 1
    chown "$username:caddy" "$home/public_html" || return 1
    chmod 2750 "$home/public_html" || return 1
    chown "$username:$username" "$home/tmp" || return 1
    chmod 700 "$home/tmp" || return 1

    prepare_log_directory "$home" || return 1
}

prepare_log_directory() {
    local home=$1

    require_caddy_user || return 1
    chown root:caddy "$home/logs" || return 1
    chmod 771 "$home/logs" || return 1
}

prepare_logs() {
    local username=$1
    local home=$2

    prepare_log_directory "$home" || return 1
    touch "$home/logs/access.log" "$home/logs/error.log" "$home/logs/php-error.log" || return 1
    chown "caddy:$username" "$home/logs/access.log" "$home/logs/error.log" || return 1
    chown "$username:$username" "$home/logs/php-error.log" || return 1
    chmod 640 "$home/logs/access.log" "$home/logs/error.log" "$home/logs/php-error.log" || return 1
}

webroot_is_empty() {
    local webroot=$1

    [[ -d "$webroot" ]] || return 1
    [[ -z "$(find "$webroot" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]]
}

download_wordpress_core() {
    local username=$1
    local home=$2
    local webroot="$home/public_html"
    local wp_home="$home/tmp"
    local wp_cache="$wp_home/wp-cli-cache"

    if ! command_exists wp; then
        echo "WP-CLI is not installed. Run setup first or skip WordPress download." >&2
        return 1
    fi
    if ! webroot_is_empty "$webroot"; then
        echo "$webroot is not empty. Refusing to download WordPress over existing files." >&2
        return 1
    fi

    prepare_wp_cli_runtime "$username" "$home" || return 1

    runuser -u "$username" -- env HOME="$wp_home" WP_CLI_CACHE_DIR="$wp_cache" wp core download --path="$webroot"
}

prepare_wp_cli_runtime() {
    local username=$1
    local home=$2
    local wp_home="$home/tmp"
    local wp_cache="$wp_home/wp-cli-cache"

    [[ "$home" == "/home/$username" ]] || return 1
    mkdir -p "$wp_cache" || return 1
    chown "$username:$username" "$wp_home" || return 1
    chown -R "$username:$username" "$wp_cache" || return 1
    chmod 700 "$wp_home" "$wp_cache" || return 1
}

run_wp_cli_for_site() {
    local username=$1
    local home=$2
    local webroot=$3
    local wp_home="$home/tmp"
    local wp_cache="$wp_home/wp-cli-cache"
    shift 3

    runuser -u "$username" -- env HOME="$wp_home" WP_CLI_CACHE_DIR="$wp_cache" wp --path="$webroot" "$@"
}

wp_cli_probe_works() {
    local username=$1
    local home=$2
    local webroot=$3
    shift 3

    run_wp_cli_for_site "$username" "$home" "$webroot" "$@" core version >/dev/null 2>&1
}

run_wp_cli_site_checks() {
    local username=$1
    local home=$2
    local webroot=$3
    local -a wp_args=()

    if wp_cli_probe_works "$username" "$home" "$webroot"; then
        wp_args=()
    elif wp_cli_probe_works "$username" "$home" "$webroot" --skip-themes; then
        echo "WP-CLI normal bootstrap failed; retrying checks with --skip-themes."
        wp_args=(--skip-themes)
    elif wp_cli_probe_works "$username" "$home" "$webroot" --skip-themes --skip-plugins; then
        echo "WP-CLI normal bootstrap failed; retrying checks with --skip-themes --skip-plugins."
        wp_args=(--skip-themes --skip-plugins)
    else
        echo "WP-CLI checks failed with normal bootstrap, --skip-themes, and --skip-themes --skip-plugins."
        return 0
    fi

    run_wp_cli_for_site "$username" "$home" "$webroot" "${wp_args[@]}" core version 2>/dev/null || true
    run_wp_cli_for_site "$username" "$home" "$webroot" "${wp_args[@]}" option get siteurl 2>/dev/null || true
    run_wp_cli_for_site "$username" "$home" "$webroot" "${wp_args[@]}" option get home 2>/dev/null || true
    run_wp_cli_for_site "$username" "$home" "$webroot" "${wp_args[@]}" plugin list --status=active 2>/dev/null || true
}

fix_site_permissions() {
    local username=$1
    local home=$2
    local webroot="$home/public_html"

    [[ "$home" == "/home/$username" ]] || return 1
    [[ -d "$webroot" ]] || return 1

    chown root:root "$home" || return 1
    chmod 751 "$home" || return 1

    require_webroot_without_symlinks "$webroot" || return 1
    require_caddy_user || return 1
    chown -R "$username:caddy" "$webroot" || return 1
    find "$webroot" -type d -exec chmod 2750 {} + || return 1
    find "$webroot" -type f -exec chmod 640 {} + || return 1

    chown "$username:$username" "$home/tmp" || return 1
    chmod 700 "$home/tmp" || return 1

    prepare_log_directory "$home" || return 1
    prepare_logs "$username" "$home"
}

create_php_pool() {
    local username=$1
    local home=$2
    local php_version=$3
    local pool

    validate_php_version "$php_version" || {
        echo "Invalid PHP version: $php_version" >&2
        return 1
    }
    validate_username "$username" || {
        echo "Invalid username: $username" >&2
        return 1
    }
    pool="/etc/php/$php_version/fpm/pool.d/$username.conf"
    require_managed_php_pool_or_missing "$pool" "PHP-FPM pool" || return 1

    write_file "$pool" <<EOF
; Managed by encodev-wh-cli
[$username]
user = $username
group = $username
listen = /run/php/php$php_version-fpm-$username.sock
listen.owner = caddy
listen.group = caddy
listen.mode = 0660
pm = dynamic
pm.max_children = 10
pm.start_servers = 2
pm.min_spare_servers = 1
pm.max_spare_servers = 3
chdir = /
php_admin_value[open_basedir] = $home/public_html:$home/tmp
php_admin_value[upload_tmp_dir] = $home/tmp
php_admin_value[session.save_path] = $home/tmp
php_admin_value[sys_temp_dir] = $home/tmp
php_admin_value[error_log] = $home/logs/php-error.log
php_admin_flag[log_errors] = on
php_admin_flag[display_errors] = off
php_admin_flag[expose_php] = off
php_admin_value[cgi.fix_pathinfo] = 0
php_admin_value[disable_functions] = $DISABLED_PHP_FUNCTIONS
EOF
}

create_database() {
    local db_name=$1
    local db_user=$2
    local db_pass=$3
    local db_identifier grant_db_identifier db_user_literal db_pass_literal db_host_literal

    db_identifier=$(mysql_database_identifier "$db_name") || return 1
    grant_db_identifier=$(mysql_grant_database_identifier "$db_name") || return 1
    db_user_literal=$(mysql_sql_string_literal "$db_user")
    db_pass_literal=$(mysql_sql_string_literal "$db_pass")
    db_host_literal=$(mysql_sql_string_literal "$DB_HOST")

    mysql -uroot <<SQL
CREATE DATABASE $db_identifier CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER $db_user_literal@'localhost' IDENTIFIED BY $db_pass_literal;
CREATE USER $db_user_literal@$db_host_literal IDENTIFIED BY $db_pass_literal;
GRANT ALL PRIVILEGES ON $grant_db_identifier.* TO $db_user_literal@'localhost';
GRANT ALL PRIVILEGES ON $grant_db_identifier.* TO $db_user_literal@$db_host_literal;
FLUSH PRIVILEGES;
SQL
}

mysql_available() {
    mysql -uroot -NBe "SELECT 1" >/dev/null 2>&1
}

mysql_database_exists() {
    local db_name=$1
    local db_literal result

    validate_database_name "$db_name" || return 1
    db_literal=$(mysql_sql_string_literal "$db_name")
    result=$(mysql -uroot -NBe "SELECT COUNT(*) FROM INFORMATION_SCHEMA.SCHEMATA WHERE SCHEMA_NAME = $db_literal" 2>/dev/null || true)
    [[ "$result" =~ ^[0-9]+$ ]] && (( result > 0 ))
}

mysql_user_exists() {
    local db_user=$1
    local db_user_literal db_host_literal result

    validate_database_name "$db_user" || return 1
    db_user_literal=$(mysql_sql_string_literal "$db_user")
    db_host_literal=$(mysql_sql_string_literal "$DB_HOST")
    result=$(mysql -uroot -NBe "SELECT COUNT(*) FROM mysql.user WHERE User = $db_user_literal AND Host IN ('localhost', $db_host_literal)" 2>/dev/null || true)
    [[ "$result" =~ ^[0-9]+$ ]] && (( result > 0 ))
}

ensure_site_can_be_created() {
    local domain=$1
    local type=$2
    local username=$3
    local home=$4
    local php_version=$5
    local create_db=$6
    local db_name=$7
    local db_user=$8
    local www_policy=${9:-none}
    local conf="$CADDY_AVAILABLE/$domain"
    local enabled="$CADDY_ENABLED/$domain"
    local pool
    local failed=0

    if path_exists "$conf"; then
        echo "Site config already exists: $conf" >&2
        failed=1
    fi
    if path_exists "$enabled"; then
        echo "Enabled site entry already exists: $enabled" >&2
        failed=1
    fi
    if path_exists "$CREDENTIALS_DIR/$domain.txt"; then
        echo "Credentials file already exists: $CREDENTIALS_DIR/$domain.txt" >&2
        failed=1
    fi
    if id "$username" >/dev/null 2>&1; then
        echo "Linux user already exists: $username" >&2
        failed=1
    fi
    if path_exists "$home"; then
        echo "Home directory already exists: $home" >&2
        failed=1
    fi
    if ! require_caddy_hosts_available "$domain" "$type" "$www_policy" "$conf"; then
        failed=1
    fi

    if [[ "$type" != "static" ]]; then
        if ! validate_php_version "$php_version"; then
            echo "Invalid PHP version: $php_version" >&2
            failed=1
        else
            pool=$(pool_path_for "$php_version" "$username")
        fi
        if [[ -n "${pool:-}" ]] && { path_exists "$pool" || path_exists "$pool.disabled"; }; then
            echo "PHP-FPM pool already exists for $username on PHP $php_version." >&2
            failed=1
        fi
    fi

    if [[ "$create_db" == "y" ]]; then
        if ! mysql_available; then
            echo "MariaDB root socket access is not available. Run setup first." >&2
            failed=1
        else
            if mysql_database_exists "$db_name"; then
                echo "Database already exists: $db_name" >&2
                failed=1
            fi
            if mysql_user_exists "$db_user"; then
                echo "Database user already exists: $db_user@localhost or $db_user@$DB_HOST" >&2
                failed=1
            fi
        fi
    fi

    (( failed == 0 ))
}

rollback_add_site() {
    local domain=$1
    local type=$2
    local username=$3
    local home=$4
    local php_version=$5
    local create_db=$6
    local db_name=$7
    local db_user=$8
    local conf="$CADDY_AVAILABLE/$domain"
    local enabled="$CADDY_ENABLED/$domain"
    local pool
    local db_identifier db_user_literal db_host_literal

    echo "Rolling back generated resources for $domain." >&2
    rm -f "$enabled"
    restore_file_from_backup "$conf"
    rm -f "$CREDENTIALS_DIR/$domain.txt"

    if [[ "$type" != "static" ]]; then
        pool=$(pool_path_for "$php_version" "$username")
        remove_managed_php_pool_if_exists "$pool"
        remove_managed_php_pool_if_exists "$pool.disabled"
        systemctl restart "php${php_version}-fpm" || true
    fi

    if [[ "$create_db" == "y" ]] && mysql_available; then
        db_identifier=$(mysql_database_identifier "$db_name") || return 0
        db_user_literal=$(mysql_sql_string_literal "$db_user")
        db_host_literal=$(mysql_sql_string_literal "$DB_HOST")
        mysql -uroot <<SQL || true
DROP USER IF EXISTS $db_user_literal@'localhost';
DROP USER IF EXISTS $db_user_literal@$db_host_literal;
DROP DATABASE IF EXISTS $db_identifier;
FLUSH PRIVILEGES;
SQL
    fi

    if id "$username" >/dev/null 2>&1; then
        userdel -r "$username" 2>/dev/null || true
    fi
    if [[ -n "$username" && "$home" == "/home/$username" ]]; then
        rm -rf "$home"
    fi
}

create_caddy_site() {
    local domain=$1
    local type=$2
    local username=$3
    local home=$4
    local php_version=$5
    local www_policy=${6:-none}
    local conf="$CADDY_AVAILABLE/$domain"
    local alias_block=""
    local site_address="$domain"
    local managed_block

    if path_exists "$conf" || path_exists "$CADDY_ENABLED/$(basename "$conf")"; then
        echo "Refusing to overwrite existing site config for $domain." >&2
        return 1
    fi

    if [[ "$domain" == www.* ]]; then
        www_policy="none"
    fi
    if [[ "$type" != "static" ]]; then
        validate_php_version "$php_version" || {
            echo "Invalid PHP version: $php_version" >&2
            return 1
        }
    fi

    case "$www_policy" in
        redirect_www)
            alias_block="www.$domain {
    redir https://$domain{uri} permanent
}

"
            ;;
        redirect_apex)
            alias_block="$domain {
    redir https://www.$domain{uri} permanent
}

"
            site_address="www.$domain"
            ;;
        serve_both)
            site_address="$domain, www.$domain"
            ;;
    esac

    if [[ "$type" == "static" ]]; then
        managed_block="    $MANAGED_BEGIN
    @sensitive_paths {
        path_regexp sensitive_paths $SENSITIVE_PATH_REGEXP
    }
    respond @sensitive_paths \"Not Found\" 404
    @executable_static_files {
        path_regexp executable_static_files $STATIC_EXECUTABLE_REGEXP
    }
    respond @executable_static_files \"Not Found\" 404
    file_server
    $MANAGED_END"
    else
        managed_block="    $MANAGED_BEGIN
    @sensitive_paths {
        path_regexp sensitive_paths $SENSITIVE_PATH_REGEXP
    }
    respond @sensitive_paths \"Not Found\" 404
    @blocked_upload_executables {
        path_regexp blocked_upload_executables $UPLOAD_EXECUTABLE_REGEXP
    }
    respond @blocked_upload_executables \"Forbidden\" 403
    @executable_static_files {
        path_regexp executable_static_files $PHP_STATIC_EXECUTABLE_REGEXP
    }
    respond @executable_static_files \"Not Found\" 404
    try_files {path} {path}/ /index.php?{query}
    php_fastcgi unix//run/php/php$php_version-fpm-$username.sock
    file_server
    $MANAGED_END"
    fi

    write_file "$conf" <<EOF
# Managed by encodev-wh-cli
# domain: $domain
# type: $type
# user: $username
# php: ${php_version:--}
# www: $www_policy
# webroot: $home/public_html

$alias_block$site_address {
    root * $home/public_html
    encode zstd gzip

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        X-Frame-Options SAMEORIGIN
    }

    log {
        output file $home/logs/access.log
    }

$managed_block
}
EOF

}

save_site_credentials() {
    local domain=$1
    local type=$2
    local username=$3
    local home=$4
    local sftp_password=$5
    local php_version=$6
    local www_policy=$7
    local wp_status=$8
    local db_name=$9
    local db_user=${10}
    local db_pass=${11}
    local db_host="-"
    local file="$CREDENTIALS_DIR/$domain.txt"
    local old_umask

    if [[ "$db_name" != "-" ]]; then
        db_host="$DB_HOST"
    fi

    old_umask=$(umask)
    umask 077
    if ! cat > "$file" <<EOF
Domain: $domain
Type: $type
System user: $username
SFTP user: $username
SFTP password: $sftp_password
Home: $home
Web root: $home/public_html
Logs: $home/logs
PHP version: ${php_version:--}
WWW policy: $(www_policy_label "$domain" "$www_policy")
WordPress files: $wp_status
Caddy config: $CADDY_AVAILABLE/$domain
Database host: $db_host
Database name: ${db_name:--}
Database user: ${db_user:--}
Database password: ${db_pass:--}
Created at: $(date -Is)
EOF
    then
        umask "$old_umask"
        return 1
    fi
    umask "$old_umask"
    chmod 600 "$file"
}

update_site_credentials_php_version() {
    local domain=$1
    local php_version=$2
    local file="$CREDENTIALS_DIR/$domain.txt"
    local tmp

    validate_php_version "$php_version" || {
        echo "Invalid PHP version: $php_version" >&2
        return 1
    }
    [[ -f "$file" ]] || return 0
    backup_file "$file" || return 1
    tmp=$(mktemp)
    if ! sed -E "s/^PHP version: .*/PHP version: $php_version/" "$file" > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    if ! install -m 0600 "$tmp" "$file"; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
}

add_site() {
    local domain type username default_username home php_version="-"
    local create_db="n" db_name="-" db_user="-" db_pass="-"
    local sftp_password www_policy download_wp="n" wp_status="skipped"

    ensure_app_dirs

    domain=$(prompt "Domain")
    domain=${domain,,}
    while ! validate_domain "$domain"; do
        echo "Enter a valid domain, for example example.com or app.example.com."
        domain=$(prompt "Domain")
        domain=${domain,,}
    done

    www_policy=$(www_policy_prompt "$domain")
    type=$(site_type_prompt)
    default_username=$(username_from_domain "$domain")
    username=$(prompt "Site username" "$default_username")
    username=${username,,}
    while ! validate_username "$username"; do
        echo "Use a Linux-safe username: lowercase letters, numbers, underscore, or dash."
        username=$(prompt "Site username" "$default_username")
        username=${username,,}
    done

    home="/home/$username"
    if [[ "$type" != "static" ]]; then
        php_version=$(select_installed_php_version) || return 0
    fi

    if [[ "$type" == "wordpress" ]]; then
        create_db="y"
        if confirm "Download latest WordPress into public_html?" "y"; then
            download_wp="y"
        fi
    elif [[ "$type" == "php" ]] && confirm "Create a MariaDB database?" "y"; then
        create_db="y"
    fi

    sftp_password=$(random_secret) || return 1
    if [[ "$create_db" == "y" ]]; then
        db_name=$(db_name_from_username "$username")
        db_user="$db_name"
        db_pass=$(random_secret) || return 1
    fi

    if ! ensure_site_can_be_created "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user" "$www_policy"; then
        echo "Site creation stopped because of the conflicts above."
        return 0
    fi

    echo
    echo "Site summary"
    echo "  Domain:      $domain"
    echo "  Type:        $type"
    echo "  User:        $username"
    echo "  Home:        $home"
    echo "  Web root:    $home/public_html"
    echo "  PHP:         $php_version"
    echo "  Database:    $create_db"
    echo "  WordPress:   $download_wp"
    echo "  WWW:         $(www_policy_label "$domain" "$www_policy")"
    echo

    if ! confirm "Create and enable this site?" "n"; then
        return 0
    fi

    start_backup_run
    if ! create_site_user "$username" "$home" "$sftp_password"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if ! prepare_logs "$username" "$home"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if [[ "$type" != "static" ]] && ! create_php_pool "$username" "$home" "$php_version"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if [[ "$create_db" == "y" ]] && ! create_database "$db_name" "$db_user" "$db_pass"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if ! create_caddy_site "$domain" "$type" "$username" "$home" "$php_version" "$www_policy"; then
        echo "Failed to create Caddy config for $domain."
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if [[ "$download_wp" == "y" ]]; then
        if ! download_wordpress_core "$username" "$home"; then
            rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
            return 1
        fi
        wp_status="downloaded"
    fi
    if ! fix_site_permissions "$username" "$home"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if ! save_site_credentials "$domain" "$type" "$username" "$home" "$sftp_password" "$php_version" "$www_policy" "$wp_status" "$db_name" "$db_user" "$db_pass"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi

    if [[ "$type" != "static" ]] && ! systemctl restart "php$php_version-fpm"; then
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    if ! enable_caddy_config "$CADDY_AVAILABLE/$domain"; then
        echo "Caddy validation or reload failed. Site config was not enabled."
        rollback_add_site "$domain" "$type" "$username" "$home" "$php_version" "$create_db" "$db_name" "$db_user"
        return 1
    fi
    prune_backups

    echo
    echo "Site created and enabled."
    echo "Domain: $domain"
    echo "SFTP user: $username"
    echo "SFTP password: $sftp_password"
    echo "SFTP path: /public_html"
    echo "Web root: $home/public_html"
    echo "WWW: $(www_policy_label "$domain" "$www_policy")"
    [[ "$type" == "wordpress" ]] && echo "WordPress files: $wp_status"
    if [[ "$create_db" == "y" ]]; then
        echo "Database host: $DB_HOST"
        echo "Database name: $db_name"
        echo "Database user: $db_user"
        echo "Database password: $db_pass"
    fi
    echo "Credentials saved to: $CREDENTIALS_DIR/$domain.txt"
    echo "Backup: $CURRENT_BACKUP_DIR"
}

site_files() {
    local file

    while IFS= read -r file; do
        grep -q '^# type: admin' "$file" && continue
        printf '%s\n' "$file"
    done < <(managed_caddy_files)
}

list_sites() {
    local file domain type user php webroot status

    printf '%-28s %-10s %-9s %-32s %-6s %s\n' "Domain" "Type" "Status" "User" "PHP" "Web root"
    printf '%-28s %-10s %-9s %-32s %-6s %s\n' "------" "----" "------" "----" "---" "--------"

    while IFS= read -r file; do
        domain=$(metadata_value domain "$file")
        type=$(metadata_value type "$file")
        user=$(metadata_value user "$file")
        php=$(metadata_value php "$file")
        webroot=$(metadata_value webroot "$file")
        status="disabled"
        [[ -L "$CADDY_ENABLED/$(basename "$file")" ]] && status="enabled"
        printf '%-28s %-10s %-9s %-32s %-6s %s\n' "$domain" "$type" "$status" "$user" "$php" "$webroot"
    done < <(site_files)
}

select_site_file() {
    local files=()
    local i selected

    mapfile -t files < <(site_files)
    if (( ${#files[@]} == 0 )); then
        echo "No managed sites found." >&2
        return 1
    fi

    echo >&2
    echo "Sites:" >&2
    for i in "${!files[@]}"; do
        printf '  %d. %s\n' "$((i + 1))" "$(metadata_value domain "${files[$i]}")" >&2
    done

    printf 'Select site: ' >&2
    read -r selected
    [[ "$selected" =~ ^[0-9]+$ ]] || return 1
    (( selected >= 1 && selected <= ${#files[@]} )) || return 1
    printf '%s\n' "${files[$((selected - 1))]}"
}

pool_path_for() {
    local php=$1
    local user=$2

    validate_php_version "$php" || {
        echo "Invalid PHP version: $php" >&2
        return 1
    }
    validate_username "$user" || {
        echo "Invalid username: $user" >&2
        return 1
    }
    printf '/etc/php/%s/fpm/pool.d/%s.conf\n' "$php" "$user"
}

update_caddy_php_version() {
    local file=$1
    local user=$2
    local old_php=$3
    local new_php=$4
    local escaped_old_php
    local tmp

    validate_php_version "$old_php" || {
        echo "Invalid current PHP version: $old_php" >&2
        return 1
    }
    validate_php_version "$new_php" || {
        echo "Invalid new PHP version: $new_php" >&2
        return 1
    }
    escaped_old_php=${old_php//./\\.}
    tmp=$(mktemp)
    if ! sed -E \
        -e "s/^# php: .*/# php: $new_php/" \
        -e "s#unix//run/php/php${escaped_old_php}-fpm-${user}\.sock#unix//run/php/php${new_php}-fpm-${user}.sock#g" \
        "$file" > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    if ! install -m 0644 "$tmp" "$file"; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
}

verify_caddy_php_version_update() {
    local file=$1
    local user=$2
    local old_php=$3
    local new_php=$4
    local old_ref new_ref

    old_ref=$(php_socket_ref "$old_php" "$user")
    new_ref=$(php_socket_ref "$new_php" "$user")

    if ! grep -Fq "$new_ref" "$file"; then
        echo "Caddy config does not reference the new PHP socket: $new_ref" >&2
        return 1
    fi

    if grep -Fq "$old_ref" "$file"; then
        echo "Caddy config still references the old PHP socket: $old_ref" >&2
        return 1
    fi
}

rollback_php_version_change() {
    local file=$1
    local new_pool=$2
    local new_pool_disabled=$3
    local old_php=$4
    local new_php=$5
    local status=$6

    echo "PHP version change failed. Restoring previous config." >&2
    restore_file_from_backup "$file"

    if path_exists "$(backup_path_for "$new_pool")"; then
        restore_file_from_backup "$new_pool"
    else
        remove_managed_php_pool_if_exists "$new_pool"
    fi

    if path_exists "$(backup_path_for "$new_pool_disabled")"; then
        restore_file_from_backup "$new_pool_disabled"
    else
        remove_managed_php_pool_if_exists "$new_pool_disabled"
    fi

    systemctl restart "php${old_php}-fpm" || true
    systemctl restart "php${new_php}-fpm" || true
    if [[ "$status" == "enabled" ]]; then
        systemctl reload caddy || true
    fi
}

change_site_php_version() {
    local file domain type user old_php new_php webroot home status old_pool new_pool
    local old_pool_disabled new_pool_disabled timestamp

    file=$(select_site_file) || return 0
    domain=$(metadata_value domain "$file")
    type=$(metadata_value type "$file")
    user=$(metadata_value user "$file")
    old_php=$(metadata_value php "$file")
    webroot=$(metadata_value webroot "$file")
    home=$(dirname "$webroot")
    status="disabled"
    [[ -L "$CADDY_ENABLED/$(basename "$file")" ]] && status="enabled"

    if [[ "$type" == "static" ]]; then
        echo "$domain is a static site and does not use PHP-FPM."
        return 0
    fi
    validate_php_version "$old_php" || {
        echo "Invalid current PHP version for $domain: $old_php" >&2
        return 1
    }

    new_php=$(select_installed_php_version) || return 0
    validate_php_version "$new_php" || {
        echo "Invalid selected PHP version: $new_php" >&2
        return 1
    }
    if [[ "$new_php" == "$old_php" ]]; then
        echo "$domain already uses PHP $new_php."
        return 0
    fi

    echo
    echo "PHP version change"
    echo "  Domain:  $domain"
    echo "  Status:  $status"
    echo "  User:    $user"
    echo "  Current: PHP $old_php"
    echo "  New:     PHP $new_php"
    echo

    if ! confirm "Change PHP version for $domain?" "n"; then
        return 0
    fi

    start_backup_run
    backup_file "$file"

    old_pool=$(pool_path_for "$old_php" "$user")
    new_pool=$(pool_path_for "$new_php" "$user")
    old_pool_disabled="$old_pool.disabled"
    new_pool_disabled="$new_pool.disabled"
    timestamp=$(date +%Y%m%d-%H%M%S)

    require_managed_php_pool_or_missing "$old_pool" "Current PHP-FPM pool" || return 1
    require_managed_php_pool_or_missing "$old_pool_disabled" "Disabled current PHP-FPM pool" || return 1
    require_managed_php_pool_or_missing "$new_pool" "Target PHP-FPM pool" || return 1
    require_managed_php_pool_or_missing "$new_pool_disabled" "Disabled target PHP-FPM pool" || return 1

    [[ -f "$old_pool" ]] && backup_file "$old_pool"
    [[ -f "$old_pool_disabled" ]] && backup_file "$old_pool_disabled"
    [[ -f "$new_pool" ]] && backup_file "$new_pool"
    [[ -f "$new_pool_disabled" ]] && backup_file "$new_pool_disabled"

    [[ -f "$new_pool" ]] && mv "$new_pool" "$new_pool.replaced.$timestamp"
    [[ -f "$new_pool_disabled" ]] && mv "$new_pool_disabled" "$new_pool_disabled.replaced.$timestamp"

    if ! create_php_pool "$user" "$home" "$new_php"; then
        rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
        return 1
    fi
    if [[ "$status" == "disabled" ]]; then
        if ! mv "$new_pool" "$new_pool_disabled"; then
            rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
            return 1
        fi
    fi

    if ! update_caddy_php_version "$file" "$user" "$old_php" "$new_php"; then
        rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
        return 1
    fi
    if ! verify_caddy_php_version_update "$file" "$user" "$old_php" "$new_php"; then
        rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
        return 1
    fi

    if [[ "$status" == "enabled" ]]; then
        if ! systemctl restart "php${new_php}-fpm"; then
            rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
            return 1
        fi
        if ! caddy validate --config /etc/caddy/Caddyfile; then
            rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
            return 1
        fi
        if ! systemctl reload caddy; then
            rollback_php_version_change "$file" "$new_pool" "$new_pool_disabled" "$old_php" "$new_php" "$status"
            return 1
        fi
    fi

    if [[ -f "$old_pool" ]]; then
        mv "$old_pool" "$old_pool.disabled.$timestamp"
    elif [[ -f "$old_pool_disabled" ]]; then
        mv "$old_pool_disabled" "$old_pool_disabled.$timestamp"
    fi

    systemctl restart "php${old_php}-fpm" || true
    if [[ "$status" != "enabled" ]]; then
        systemctl restart "php${new_php}-fpm" || true
    fi
    if ! update_site_credentials_php_version "$domain" "$new_php"; then
        echo "Warning: site PHP changed, but credentials metadata was not updated." >&2
    fi
    prune_backups

    echo "$domain now uses PHP $new_php."
    echo "Backup: $CURRENT_BACKUP_DIR"
}

disable_site() {
    local file domain type user php pool enabled timestamp

    file=$(select_site_file) || return 0
    domain=$(metadata_value domain "$file")
    type=$(metadata_value type "$file")
    user=$(metadata_value user "$file")
    php=$(metadata_value php "$file")
    enabled="$CADDY_ENABLED/$(basename "$file")"

    if ! confirm "Disable $domain? Files and database will stay untouched." "n"; then
        return 0
    fi

    if ! path_exists "$enabled"; then
        echo "$domain is already disabled."
        return 0
    fi
    if [[ "$type" != "static" ]]; then
        validate_php_version "$php" || {
            echo "Invalid PHP version for $domain: $php" >&2
            return 1
        }
        pool=$(pool_path_for "$php" "$user") || return 1
        if path_exists "$pool"; then
            require_managed_php_pool_or_missing "$pool" "PHP-FPM pool" || return 1
        fi
        if path_exists "$pool.disabled"; then
            require_managed_php_pool_or_missing "$pool.disabled" "Disabled PHP-FPM pool" || return 1
        fi
    fi

    start_backup_run
    backup_file "$file"
    backup_file "$enabled"

    rm -f "$enabled"
    if ! caddy validate --config /etc/caddy/Caddyfile; then
        restore_file_from_backup "$enabled"
        echo "Caddy validation failed. Site was not disabled."
        return 1
    fi
    if ! systemctl reload caddy; then
        restore_file_from_backup "$enabled"
        systemctl reload caddy || true
        echo "Caddy reload failed. Site was not disabled."
        return 1
    fi

    if [[ "$type" != "static" ]]; then
        if path_exists "$pool"; then
            backup_file "$pool"
            timestamp=$(date +%Y%m%d-%H%M%S)
            if path_exists "$pool.disabled"; then
                backup_file "$pool.disabled"
                mv "$pool.disabled" "$pool.disabled.$timestamp"
            fi
            mv "$pool" "$pool.disabled"
            if ! systemctl restart "php${php}-fpm"; then
                echo "Warning: Caddy stopped serving $domain, but PHP-FPM restart failed after disabling its pool." >&2
            fi
        fi
    fi

    prune_backups
    echo "$domain disabled. Files and database were not modified."
}

enable_site() {
    local file domain type user php pool pool_enabled=0
    local pool_replaced="" timestamp

    file=$(select_site_file) || return 0
    domain=$(metadata_value domain "$file")
    type=$(metadata_value type "$file")
    user=$(metadata_value user "$file")
    php=$(metadata_value php "$file")

    if ! confirm "Enable $domain?" "y"; then
        return 0
    fi
    if [[ "$type" != "static" ]]; then
        validate_php_version "$php" || {
            echo "Invalid PHP version for $domain: $php" >&2
            return 1
        }
        pool=$(pool_path_for "$php" "$user") || return 1
        if path_exists "$pool.disabled"; then
            require_managed_php_pool_or_missing "$pool.disabled" "Disabled PHP-FPM pool" || return 1
            if path_exists "$pool"; then
                require_managed_php_pool_or_missing "$pool" "PHP-FPM pool" || return 1
            fi
        elif path_exists "$pool"; then
            require_managed_php_pool_or_missing "$pool" "PHP-FPM pool" || return 1
        else
            echo "Missing PHP-FPM pool for $domain: $pool" >&2
            echo "Use Change site PHP version or recreate the managed pool before enabling." >&2
            return 1
        fi
    fi

    start_backup_run

    if [[ "$type" != "static" ]]; then
        if path_exists "$pool.disabled"; then
            backup_file "$pool.disabled"
            if path_exists "$pool"; then
                backup_file "$pool"
                timestamp=$(date +%Y%m%d-%H%M%S)
                pool_replaced="$pool.replaced.$timestamp"
                mv "$pool" "$pool_replaced" || return 1
            fi
            mv "$pool.disabled" "$pool"
            pool_enabled=1
            if ! systemctl restart "php${php}-fpm"; then
                mv "$pool" "$pool.disabled" || true
                if [[ -n "$pool_replaced" ]]; then
                    mv "$pool_replaced" "$pool" || true
                fi
                systemctl restart "php${php}-fpm" || true
                echo "PHP-FPM restart failed. Site was not enabled." >&2
                return 1
            fi
        fi
    fi

    if ! enable_caddy_config "$file"; then
        if [[ "$pool_enabled" -eq 1 ]]; then
            mv "$pool" "$pool.disabled" || true
            if [[ -n "$pool_replaced" ]]; then
                mv "$pool_replaced" "$pool" || true
            fi
            systemctl restart "php${php}-fpm" || true
        fi
        echo "Caddy validation or reload failed. Site was not enabled."
        return 1
    fi
    prune_backups
    echo "$domain enabled."
}

scan_server() {
    local apache_packages apache_configs htaccess_hits listeners

    echo
    echo "Server scan"
    print_status

    echo "Web server conflicts:"
    if service_is_active apache2 || service_is_active nginx || service_is_enabled apache2 || service_is_enabled nginx; then
        service_is_active apache2 && echo "  apache2: active"
        service_is_enabled apache2 && echo "  apache2: enabled"
        service_is_active nginx && echo "  nginx: active"
        service_is_enabled nginx && echo "  nginx: enabled"
    else
        echo "  none active or enabled"
    fi
    echo

    if command_exists ss; then
        listeners=$(ss -ltnp 2>/dev/null | awk '$4 ~ /:(80|443)$/ { print "  " $0 }' | head -n 10 || true)
        if [[ -n "$listeners" ]]; then
            echo "Port 80/443 listeners:"
            echo "$listeners"
            echo
        fi
    fi

    if command_exists dpkg-query; then
        apache_packages=$(dpkg-query -W -f='${binary:Package} ${db:Status-Abbrev}\n' 'apache2*' 'libapache2-mod-php*' 2>/dev/null \
            | awk '$2 == "ii" { print "  " $1 }' || true)
        if [[ -n "$apache_packages" ]]; then
            echo "Installed Apache-related packages:"
            echo "$apache_packages"
            echo
        fi
    fi

    if [[ -d /etc/apache2 ]]; then
        apache_configs=$(grep -RInE '^[[:space:]]*(ServerName|ServerAlias|DocumentRoot|ProxyPass|SetHandler|Directory|VirtualHost|Listen)[[:space:]]+' \
            /etc/apache2 2>/dev/null | head -n 30 || true)
        if [[ -n "$apache_configs" ]]; then
            echo "Apache config entries to review for migration:"
            echo "$apache_configs"
            echo
        fi
    fi

    htaccess_hits=$(find /var/www /home -name .htaccess -type f 2>/dev/null | head -n 20 || true)
    if [[ -n "$htaccess_hits" ]]; then
        echo ".htaccess files found; Caddy ignores them:"
        echo "$htaccess_hits"
        echo
    fi

    if command_exists caddy && [[ -f /etc/caddy/Caddyfile ]]; then
        caddy validate --config /etc/caddy/Caddyfile
    fi

    echo "Server scan complete."
}

scan_site() {
    local file domain type user php webroot home status symlink_hits upload_hits executable_hits htaccess_hits hardcoded_hits pool

    file=$(select_site_file) || return 0
    domain=$(metadata_value domain "$file")
    type=$(metadata_value type "$file")
    user=$(metadata_value user "$file")
    php=$(metadata_value php "$file")
    webroot=$(metadata_value webroot "$file")
    home=$(dirname "$webroot")
    status="disabled"
    [[ -L "$CADDY_ENABLED/$(basename "$file")" ]] && status="enabled"

    echo
    echo "Scan: $domain"
    echo "  Type: $type"
    echo "  Status: $status"
    echo "  User: $user"
    echo "  PHP: $php"
    echo "  Web root: $webroot"
    echo

    [[ -d "$webroot" ]] || { echo "Missing web root."; return 0; }

    if [[ -L "$webroot" ]]; then
        symlink_hits=$webroot
    else
        symlink_hits=$(find "$webroot" -type l -print 2>/dev/null | head -n 5 || true)
    fi
    if [[ -n "$symlink_hits" ]]; then
        echo "Symlinks found in web root; managed sites refuse to enable with symlinks:"
        echo "$symlink_hits"
        echo
    fi

    if [[ "$type" != "static" ]]; then
        validate_php_version "$php" || {
            echo "Invalid PHP version for $domain: $php"
            return 0
        }
        pool=$(pool_path_for "$php" "$user")
        if [[ ! -f "$pool" && "$status" == "enabled" ]]; then
            echo "Missing active PHP-FPM pool for enabled site: $pool"
            echo
        elif [[ ! -f "$pool" && ! -f "$pool.disabled" ]]; then
            echo "Missing PHP-FPM pool: $pool"
            echo
        fi
    fi

    if [[ "$type" == "static" ]]; then
        executable_hits=$(find "$webroot" -type f 2>/dev/null \
            | awk 'tolower($0) ~ /\.(php[0-9]?|phtml|phar|phps|cgi|pl|py|rb|sh|bash|zsh|ksh)$/ { print }' \
            | head -n 5 || true)
    else
        executable_hits=$(find "$webroot" -type f 2>/dev/null \
            | awk 'tolower($0) ~ /\.(php[0-9]+|phtml|phar|phps|cgi|pl|py|rb|sh|bash|zsh|ksh)$/ { print }' \
            | head -n 5 || true)
    fi
    if [[ -n "$executable_hits" ]]; then
        echo "Static executable-like files found:"
        echo "$executable_hits"
        echo
    fi

    htaccess_hits=$(find "$webroot" -name .htaccess -type f 2>/dev/null | head -n 5 || true)
    if [[ -n "$htaccess_hits" ]]; then
        echo ".htaccess files found; Caddy ignores them:"
        echo "$htaccess_hits"
        echo
    fi

    upload_hits=$(find "$webroot/wp-content/uploads" "$webroot/uploads" "$webroot/data" "$webroot/cache" \
        -type f 2>/dev/null \
        | awk 'tolower($0) ~ /\.(php[0-9]?|phtml|phar|phps|cgi|pl|py|rb|sh|bash|zsh|ksh)$/ { print }' \
        | head -n 5 || true)
    if [[ -n "$upload_hits" ]]; then
        echo "Executable-like files found in upload/data/cache paths:"
        echo "$upload_hits"
        echo
    fi

    hardcoded_hits=$(grep -RIl --include='*.php' --include='*.sql' --include='*.ini' \
        -e '/var/www/' -e 'www-data' "$webroot" 2>/dev/null | head -n 5 || true)
    if [[ -n "$hardcoded_hits" ]]; then
        echo "Legacy Apache/path references found:"
        echo "$hardcoded_hits"
        echo
    fi

    if [[ -f "$webroot/wp-config.php" ]] && command_exists wp; then
        echo "WordPress detected. Running WP-CLI checks as $user..."
        if prepare_wp_cli_runtime "$user" "$home"; then
            run_wp_cli_site_checks "$user" "$home" "$webroot"
        else
            echo "Could not prepare WP-CLI cache under $home/tmp; skipping WP-CLI checks."
        fi
        echo
    fi

    if command_exists caddy && [[ -f /etc/caddy/Caddyfile ]]; then
        caddy validate --config /etc/caddy/Caddyfile
    else
        echo "Caddy is not installed or /etc/caddy/Caddyfile is missing."
    fi
    echo "Scan complete."
}

is_managed_tmp_dir() {
    local dir=$1

    if [[ "$dir" == "$ADMINER_TMP_DIR" ]]; then
        return 0
    fi
    [[ "$dir" =~ ^/home/site_[a-z0-9_-]+/tmp$ ]]
}

cleanup_tmp_dir() {
    local dir=$1
    local label=$2
    local file_count dir_count

    if ! is_managed_tmp_dir "$dir"; then
        echo "Refusing unexpected tmp directory: $dir" >&2
        return 1
    fi
    if [[ ! -d "$dir" ]]; then
        printf '  %-36s skipped (missing)\n' "$label"
        return 0
    fi
    if [[ -L "$dir" ]]; then
        echo "Refusing symlinked tmp directory: $dir" >&2
        return 1
    fi

    if ! file_count=$(find "$dir" -xdev -ignore_readdir_race -type f -mmin +"$MAINTENANCE_RETENTION_MINUTES" -delete -printf '.' | wc -c); then
        echo "Failed to clean stale files under: $dir" >&2
        return 1
    fi
    file_count=${file_count//[[:space:]]/}
    if ! dir_count=$(find "$dir" -xdev -ignore_readdir_race -mindepth 1 -type d -empty -mmin +"$MAINTENANCE_RETENTION_MINUTES" -delete -printf '.' | wc -c); then
        echo "Failed to clean empty directories under: $dir" >&2
        return 1
    fi
    dir_count=${dir_count//[[:space:]]/}

    printf '  %-36s %s files, %s empty dirs\n' "$label" "$file_count" "$dir_count"
}

run_maintenance() {
    local dir label failed=0
    local nullglob_was_set=0

    echo "Maintenance cleanup"
    echo "Retention: $MAINTENANCE_RETENTION_DAYS days"

    shopt -q nullglob && nullglob_was_set=1
    shopt -s nullglob
    for dir in /home/site_*/tmp; do
        label=${dir#/home/}
        cleanup_tmp_dir "$dir" "$label" || failed=1
    done
    if (( nullglob_was_set == 0 )); then
        shopt -u nullglob
    fi

    cleanup_tmp_dir "$ADMINER_TMP_DIR" "adminer-tmp" || failed=1

    if (( failed != 0 )); then
        echo "Maintenance completed with errors." >&2
        return 1
    fi
    echo "Maintenance complete."
}

print_status() {
    local enabled disabled
    local php_versions
    enabled=0
    disabled=0

    while IFS= read -r file; do
        if [[ -L "$CADDY_ENABLED/$(basename "$file")" ]]; then
            ((enabled += 1))
        else
            ((disabled += 1))
        fi
    done < <(site_files)

    echo "Status:"
    echo "  Caddy:   $(service_state caddy)"
    echo "  MariaDB: $(service_state mariadb)"
    echo "  UFW:     $(command_exists ufw && ufw status 2>/dev/null | head -n 1 | sed 's/^Status: //' || printf 'missing')"
    php_versions=$(installed_php_versions | paste -sd ',' - 2>/dev/null || true)
    [[ -z "$php_versions" ]] && php_versions="missing"
    echo "  PHP-FPM: $php_versions"
    echo "  Sites:   $enabled enabled, $disabled disabled"
    echo
}

main_menu() {
    local choice

    while true; do
        clear || true
        echo "$APP_NAME"
        echo
        print_status
        echo "1. Setup server"
        echo "2. Add site"
        echo "3. List sites"
        echo "4. Disable site"
        echo "5. Enable site"
        echo "6. Change site PHP version"
        echo "7. Install PHP version"
        echo "8. Scan server"
        echo "9. Scan site"
        echo "10. Exit"
        echo
        read -r -p "Choose an option: " choice

        case "$choice" in
            1) setup_server; pause ;;
            2) add_site; pause ;;
            3) list_sites; pause ;;
            4) disable_site; pause ;;
            5) enable_site; pause ;;
            6) change_site_php_version; pause ;;
            7) install_php_versions_menu; pause ;;
            8) scan_server; pause ;;
            9) scan_site; pause ;;
            10) exit 0 ;;
            *) echo "Invalid option."; pause ;;
        esac
    done
}

main() {
    require_root

    if (( $# > 0 )); then
        case "$1" in
            maintenance)
                shift
                if (( $# != 0 )); then
                    echo "Usage: sudo wh maintenance" >&2
                    exit 1
                fi
                run_maintenance
                exit $?
                ;;
            *)
                echo "Usage: sudo wh [maintenance]" >&2
                exit 1
                ;;
        esac
    fi

    ensure_app_dirs
    main_menu
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
